{
  "name": "mermify",
  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run license:check && tsc -b && vite build && bun run docs:build && bun run scripts/copy-docs-to-dist.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:video": "VIDEO=on playwright test",
    "license:check": "bun scripts/check-licenses.ts",
    "docs:dev": "bun run vitepress dev docs",
    "docs:build": "bun run vitepress build docs",
    "docs:preview": "bun run vitepress preview docs",
    "deploy:docs": "bun run docs:build && gh-pages -d docs/.vitepress/dist",
    "docs:screenshots": "bun playwright test e2e/screenshots.spec.ts"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^1.21.0",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.55.1",
    "pako": "^2.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "^20.10.6",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  }
}